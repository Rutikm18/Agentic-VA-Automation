# Copy to probe.env and edit for the network you're deploying onto.

# Platform the probe reports to (required)
PLATFORM_URL=https://intrynx.example.com

# Deployment license (required) — the host-locked token your administrator issued.
# The probe will not run without a valid license for THIS machine.
#   • find this machine's Host ID:   ./probe hostid
#   • alternatively point to a file: LICENSE_FILE=/etc/intrynx/license.key
PROBE_LICENSE=
# In containers the OS machine-id is not stable — set a fixed id and mint the
# license against it (run "./probe hostid" once inside the container to read it):
# PROBE_HOST_ID=acme-dmz-probe-01

# Identity — choose ONE method:
#  (a) operator login: the probe logs in and self-registers
OPERATOR_EMAIL=admin@adversa.io
OPERATOR_PASSWORD=ChangeMe123!
#  (b) pre-provisioned: register once via the API, then pin the values here
# AGENT_ID=
# AGENT_TOKEN=

# Probe identity / scope
PROBE_NAME=dmz-probe-01
PROBE_LOCATION=DMZ - rack 4
# Capabilities are AUTO-DETECTED from the available scan engines. Uncomment to
# override, e.g. limit a probe to a subset of scan_types:
# PROBE_CAPABILITIES=discovery,vuln_scan,mcp_discovery,ai_service_discovery
PROBE_NETWORK_SEGMENTS=10.0.1.0/24,10.0.2.0/24

# Behaviour
HEARTBEAT_INTERVAL=30
POLL_INTERVAL=10
JOB_LIMIT=1
# Default discovery-engine flags (legacy NMAP_DEFAULT_ARGS still honoured)
SCAN_DEFAULT_ARGS=-sV -T4 -Pn
# Fallback targets if a discovery job carries none (otherwise the job fails fast)
PROBE_DEFAULT_TARGETS=
# Set false only for self-signed platform TLS (lab use)
VERIFY_TLS=true
