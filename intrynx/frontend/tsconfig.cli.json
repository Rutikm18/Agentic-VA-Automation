{
  "compilerOptions": {
    "target":           "ES2020",
    "module":           "CommonJS",
    "moduleResolution": "node",
    "lib":              ["ES2020"],
    "outDir":           "./dist",
    "rootDir":          ".",
    "strict":           false,
    "esModuleInterop":  true,
    "resolveJsonModule": true,
    "skipLibCheck":     true,
    "noEmit":           false
  },
  "include": ["cli/**/*.ts", "lib/**/*.ts"],
  "exclude": ["app/**", "components/**", "node_modules", "dist", "lib/ai-engine.ts", "lib/openvas-client.ts", "lib/scan-pipeline.ts"]
}
