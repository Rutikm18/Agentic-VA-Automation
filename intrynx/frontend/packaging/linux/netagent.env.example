# /etc/netagent/netagent.env — per-install probe configuration.
# Manager URL + cert/signing pins are baked into the binary; you normally only set the
# one-time enroll token here. Remove it after first successful enrollment.

PROBE_ENROLL_TOKEN=PASTE-ONE-TIME-ENROLL-TOKEN-HERE

# Optional overrides (usually unnecessary — baked at build):
# PROBE_MANAGER_URL=https://acme.dash.example.com
# PROBE_LOG_LEVEL=INFO
