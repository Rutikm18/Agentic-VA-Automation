# /Library/Application Support/netagent/netagent.env — per-install probe configuration.
# Manager URL + pins are baked into the binary; set the one-time enroll token here, then
# remove it after first successful enrollment.

PROBE_ENROLL_TOKEN=PASTE-ONE-TIME-ENROLL-TOKEN-HERE

# Optional overrides:
# PROBE_MANAGER_URL=https://acme.dash.example.com
# PROBE_LOG_LEVEL=INFO
