# Copy to .env (docker compose reads it automatically): cp .env.docker.example .env

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_USER=vapt
POSTGRES_PASSWORD=secret
POSTGRES_DB=vapt_db
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PORT=6379

# ── API ───────────────────────────────────────────────────────────────────────
API_PORT=18080
API_WORKERS=4
APP_ENV=production
LOG_LEVEL=INFO
# CHANGE THIS — must be >= 32 chars. Generate: openssl rand -base64 48
JWT_SECRET=change-me-please-to-a-long-random-secret-value!!

# Build the API image with heavy integrations (AI/AD/Neo4j). 0 = lean (default).
INSTALL_EXTRAS=0

# ── First-run admin (seeded once by the `migrate` service) ────────────────────
SEED_ADMIN_EMAIL=admin@adversa.io
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_TENANT_NAME=Default Tenant

# ── Neo4j (only used with `--profile graph`) ──────────────────────────────────
NEO4J_ENABLED=false
NEO4J_USER=neo4j
NEO4J_PASSWORD=adversa-neo4j
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# ── AI engine (optional) ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-6

# ── Local probe (only used with `--profile probe`) ────────────────────────────
PROBE_NAME=local-probe
PROBE_NETWORK_SEGMENTS=
